# Copia este archivo como ".env" en la raíz del proyecto y completa los valores reales.
# El ".env" real NUNCA debe subirse a GitHub (ya está en .gitignore).

# Base de datos (para desarrollo local con Docker Compose puedes dejar los valores por defecto;
# para producción con Supabase, usa las credenciales del panel de Supabase > Project Settings > Database)
DB_NAME=MH_G6_BD
DB_USER=postgres
DB_PASSWORD=postgre

# Si despliegas directamente contra Supabase (sin Docker), define además la URL completa:
# SPRING_DATASOURCE_URL=jdbc:postgresql://<host-supabase>:5432/postgres
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=<password-supabase>

# Firma de tokens JWT (genera un valor largo y aleatorio distinto para producción)
JWT_SECRET=

# Llave AES para cifrar mensajes de terapia (debe tener exactamente 16 caracteres)
ENCRYPTION_KEY=

# Google Gemini (IA de terapia)
GEMINI_API_KEY=

# SMTP Gmail (envío real de correos: verificación, recuperación, alertas, coordinaciones)
MAIL_USERNAME=
MAIL_APP_PASSWORD=
