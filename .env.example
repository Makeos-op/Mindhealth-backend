# Copia este archivo como ".env" en la raíz del proyecto y completa los valores reales.
# El ".env" real NUNCA debe subirse a GitHub (ya está en .gitignore).

# Base de datos (para desarrollo local con Docker Compose puedes dejar los valores por defecto;
# para producción con Supabase, usa las credenciales del panel de Supabase > Project Settings > Database)
DB_NAME=MH_G6_BD
DB_USER=postgres
DB_PASSWORD=postgre

# Si despliegas directamente contra Supabase (sin Docker), define además la URL completa:
# SPRING_DATASOURCE_URL=jdbc:postgresql://<host-supabase>:5432/postgres
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=<password-supabase>

# Firma de tokens JWT (genera un valor largo y aleatorio distinto para producción)
JWT_SECRET=

# Llave AES para cifrar mensajes de terapia (debe tener exactamente 16 caracteres)
ENCRYPTION_KEY=

# Google Gemini (IA de terapia)
GEMINI_API_KEY=

# Brevo (envío real de correos vía API HTTP: verificación, recuperación, alertas, coordinaciones)
# Necesario porque muchas plataformas de hosting (Render, Railway, etc.) bloquean SMTP saliente.
# Crea una cuenta gratis en https://brevo.com, genera una API key (SMTP & API > API Keys),
# y verifica un "remitente único" (Senders > Add a sender) con tu propio correo — no requiere dominio.
BREVO_API_KEY=

# Debe ser exactamente el correo que verificaste como remitente único en Brevo.
MAIL_REMITENTE=

# URLs usadas para armar los enlaces de los correos (verificacion de cuenta y recuperacion de password).
# En produccion: APP_BASE_URL = URL publica del backend (Render), FRONTEND_BASE_URL = URL publica del frontend (Vercel).
APP_BASE_URL=https://mindhealth-backend.onrender.com
FRONTEND_BASE_URL=https://mindhealth-frontend.vercel.app
